---
import { Terminal } from "@lucide/astro";
import BaseLayout from "../layouts/base-layout.astro";
import "../styles/global.css";
---

<BaseLayout
	title="404 | NonSwag"
	description="Page not found"
>
	<div class="min-h-screen bg-black text-primary font-mono flex flex-col justify-center items-center p-4">
		<Terminal size={64} class="mb-8" />
		<h1
			class="text-4xl md:text-6xl font-bold mb-4 glitch"
			data-text="404_NOT_FOUND"
		>
			404_NOT_FOUND
		</h1>
		<p class="text-xl md:text-2xl mb-8 text-center">
			The page you are looking for has been moved, deleted, or never existed.
		</p>
		<div class="text-lg md:text-xl mb-8 flex items-center">
			<span class="mr-2">&gt;</span>
			<span>cd /home</span>
			<span id="cursor" class="w-3 h-6 bg-primary ml-1"></span>
		</div>
		<a
			href="/"
			class="bg-primary text-black px-6 py-3 rounded-full font-semibold hover:bg-hover transition-colors"
		>
			Return to Base
		</a>
	</div>
	<script>
		const cursor = document.getElementById("cursor");
		if (cursor) {
			setInterval(() => cursor.classList.toggle("opacity-0"), 500);
		}
	</script>
</BaseLayout>
